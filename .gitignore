# ============================================
# MultiBet .gitignore — atualizado 20/03/2026
# ============================================

# Credenciais — NUNCA subir pro Git
.env
*.env.*
ec2_deploy/.env
*credentials*.json
*service_account*.json
dwh-ext-24105.json
*.pem
*.key
!*.pub.key
bastion-*.pem
etl-*.pem

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Outputs (dados gerados — não são código)
*.csv
!pipelines/jogos.csv
*.xlsx
*.html
output/
outputs/
analysis/output/
segmentacao_output_*/

# Logs
*.log
pipelines/logs/
segmentacao/app/logs/

# Memory (local do Claude Code)
memory/

# Pastas de validacao tecnica interna (so pro Mateus, nao vai pro repo do squad)
_internal_*/

# IDE
.vscode/
*.code-workspace

# Build artifacts
build/
dist/
*.zip
*.mp4
*.pdf

# Claude / Agentes (config local)
.agents/
.claude/
!.claude/agents/
.claude-flow/
.mcp.json
skills-lock.json

# Arquivos acidentais (fragmentos de terminal)
# Regra genérica: ignorar arquivos de 1-3 chars sem extensão na raiz
# e fragmentos SQL/Python que vazaram como nomes de arquivo
[0-9]
[0-9][0-9]
[0-9][0-9][0-9]
D[0-9]
D[0-9][0-9]

# Outputs específicos de validações e reports
validacoes/*.csv
validacoes/*.zip
reports/*.csv

# Matriz de risco outputs
matriz_de_risco/Arquivos CSV*/
matriz_de_risco/_WITH_*.csv

# Solicitações pontuais outputs
solicitacoes_pontuais/**/*.csv
solicitacoes_pontuais/**/*.xlsx

# Segmentação outputs por jogo
segmentacao/*/output_*/

# Anti-abuse deploy artifacts
anti_abuse_deploy/.env
anti_abuse_deploy/*.zip
ec2_deploy/*.zip

# Temporários do OS
Thumbs.db
.DS_Store
*.tmp
~$*
google ads/*.json
data/
alerta-ftd/

# Arquivo (pastas obsoletas preservadas localmente)
_archive/

# Backups automaticos (git ja eh sistema de versionamento)
*.bak
*.bak_*
*.bkp
*.bkp_*

# Clones de outros repos (nunca commitar)
_clones/
_workdir_migration/

# Pastas de exploracao / projetos paralelos (nao-MultiBet core)
temp/                               # scripts exploratorios, validacao ad-hoc
caixinhas/                          # placeholder, nao-core
clustering-btr-utm-campaign/        # projeto separado, rodar isoladamente

# Fragmentos adicionais de terminal (heredocs/quotes escapados)
/[{}()\[\]'\`$]*
/[A-Z][A-Z][A-Z]
/R$*
/{*
/(*
/{[,.:]
/d.*
/c_*
/u_*
