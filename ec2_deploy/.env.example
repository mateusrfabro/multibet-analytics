# =============================================================
# Athena - AWS Iceberg Data Lake (read-only)
# =============================================================
ATHENA_AWS_ACCESS_KEY_ID=
ATHENA_AWS_SECRET_ACCESS_KEY=
ATHENA_S3_STAGING=s3://BUCKET_NAME/
ATHENA_REGION=sa-east-1

# =============================================================
# BigQuery - Smartico CRM
# =============================================================
BIGQUERY_CREDENTIALS_PATH=/home/ec2-user/multibet/bigquery_credentials.json
BIGQUERY_PROJECT_ID=smr-dwh

# =============================================================
# Super Nova DB (PostgreSQL via SSH tunnel)
# =============================================================
BASTION_HOST=
BASTION_USER=ec2-user
SUPERNOVA_PEM_PATH=/home/ec2-user/multibet/bastion-analytics-key.pem
SUPERNOVA_HOST=
SUPERNOVA_DB=supernova_db
SUPERNOVA_USER=analytics_user
SUPERNOVA_PASS=

# =============================================================
# Slack Webhooks
# =============================================================
SLACK_WEBHOOK_MULTIVERSO=
